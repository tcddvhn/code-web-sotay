{
  "entities": {
    "DataRow": {
      "title": "Dữ liệu tổng hợp",
      "description": "Một hàng dữ liệu từ file Excel của đơn vị",
      "type": "object",
      "properties": {
        "unitCode": { "type": "string", "description": "Mã đơn vị" },
        "year": { "type": "string", "description": "Năm báo cáo" },
        "sheetName": { "type": "string", "description": "Tên biểu mẫu (ví dụ: 1B, 5A)" },
        "sourceRow": { "type": "number", "description": "Số hàng trong file gốc" },
        "label": { "type": "string", "description": "Tên tiêu chí" },
        "values": { "type": "array", "items": { "type": "number" }, "description": "Các giá trị số liệu" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Thời gian cập nhật" }
      },
      "required": ["unitCode", "year", "sheetName", "sourceRow", "label", "values"]
    },
    "AppSettings": {
      "title": "Cấu hình hệ thống",
      "description": "Các cài đặt chung của ứng dụng",
      "type": "object",
      "properties": {
        "oneDriveLink": { "type": "string", "description": "Link OneDrive lưu trữ" },
        "storagePath": { "type": "string", "description": "Đường dẫn lưu file gốc" },
        "receivedPath": { "type": "string", "description": "Đường dẫn lưu file đã nhận" }
      }
    }
  },
  "firestore": {
    "/consolidated_data/{rowId}": {
      "schema": "DataRow",
      "description": "Bộ lưu trữ toàn bộ dữ liệu đã được tổng hợp"
    },
    "/settings/global": {
      "schema": "AppSettings",
      "description": "Cấu hình hệ thống duy nhất"
    }
  }
}
