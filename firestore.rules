rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAllowedEmail() {
      return request.auth.token.email in [
        "admin@sotay.com",
        "trieuthingoc@sotay.com",
        "tranthikieuanh@sotay.com",
        "tranphuongha@sotay.com",
        "phamthithuhanh@sotay.com",
        "nguyenthugiang@sotay.com",
        "nguyensinghiem@sotay.com",
        "nguyenhuuhung@sotay.com"
      ];
    }

    function isAdmin() {
      return isAuthenticated() && isAllowedEmail() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          request.auth.token.email == "admin@sotay.com");
    }

    function isContributor() {
      return isAuthenticated() && isAllowedEmail() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'contributor']) ||
          request.auth.token.email == "admin@sotay.com");
    }

    function isValidUserProfile(data, userId) {
      return data.id == userId &&
             data.email is string &&
             data.email == request.auth.token.email &&
             (!('displayName' in data) || data.displayName is string || data.displayName == null) &&
             data.role in ['admin', 'contributor'] &&
             (
               (request.auth.token.email == "admin@sotay.com" && data.role == 'admin') ||
               (request.auth.token.email != "admin@sotay.com" && data.role == 'contributor')
             );
    }

    function isValidDataRow(data) {
      return data.unitCode is string && data.unitCode.size() > 0 &&
             data.year is string && data.year.size() == 4 &&
             data.projectId is string && data.projectId.size() > 0 &&
             data.templateId is string && data.templateId.size() > 0 &&
             data.sourceRow is number &&
             data.label is string &&
             data.values is list &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidProject(data) {
      return data.name is string && data.name.size() > 0 &&
             data.status in ['ACTIVE', 'COMPLETED'];
    }

    function isValidTemplate(data) {
      return data.projectId is string &&
             data.name is string &&
             data.columnMapping is map &&
             data.columnMapping.labelColumn is string &&
             data.columnMapping.dataColumns is list;
    }

    function isValidSettings(data) {
      return (!('oneDriveLink' in data) || data.oneDriveLink is string) &&
             (!('storagePath' in data) || data.storagePath is string) &&
             (!('receivedPath' in data) || data.receivedPath is string);
    }

    function isValidReportExport(data) {
      return data.projectId is string &&
             data.templateId is string &&
             data.year is string &&
             data.fileName is string &&
             data.storagePath is string;
    }

    function isValidUnit(data) {
      return data.code is string &&
             data.name is string &&
             (!('isDeleted' in data) || data.isDeleted is bool);
    }

    match /consolidated_data/{rowId} {
      allow read: if isContributor() || request.auth == null;
      allow create, update: if isAdmin() && isValidDataRow(request.resource.data);
      allow delete: if isAdmin();
    }

    match /consolidated_data_v2/{rowId} {
      allow read: if isContributor() || request.auth == null;
      allow create, update: if isContributor() && isValidDataRow(request.resource.data);
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isContributor() || request.auth == null;
      allow create, update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    match /templates/{templateId} {
      allow read: if isContributor() || request.auth == null;
      allow create, update: if isAdmin() && isValidTemplate(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/global {
      allow read: if isContributor();
      allow create, update: if isAdmin() && isValidSettings(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/migrations {
      allow read: if isContributor();
      allow write: if isAdmin();
    }

    match /report_exports/{docId} {
      allow read: if isContributor();
      allow create: if isContributor() && isValidReportExport(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUserProfile(request.resource.data, userId);
      allow update: if (isAuthenticated() && request.auth.uid == userId && isValidUserProfile(request.resource.data, userId)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /assignments/{assignmentId} {
      allow read: if isContributor();
      allow write: if isAdmin();
    }

    match /units/{unitId} {
      allow read: if isContributor();
      allow create, update: if isAdmin() && isValidUnit(request.resource.data);
      allow delete: if false;
    }
  }
}
